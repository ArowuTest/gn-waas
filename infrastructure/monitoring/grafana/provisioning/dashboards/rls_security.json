{
  "__inputs": [{"name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus"}],
  "description": "GN-WAAS Row-Level Security monitoring: RLS transaction failures, bypass events, enforcement rate, and district data isolation health.",
  "editable": false,
  "graphTooltip": 1,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "title": "RLS Enforcement Status",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [{"options": {"0": {"color": "green", "index": 0, "text": "SECURE"}, "1": {"color": "red", "index": 1, "text": "DEGRADED"}}, "type": "value"}],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}
        }
      },
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 1},
      "id": 2,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "auto"},
      "title": "RLS Status (last 5 min)",
      "description": "GREEN = all requests enforced RLS. RED = at least one RLS bypass detected in the last 5 minutes.",
      "type": "stat",
      "targets": [{"expr": "clamp_max(increase(gnwaas_log_lines_total{service=\"api-gateway\",level=\"warn\",message=~\".*RLS middleware.*failed.*\"}[5m]), 1)", "legendFormat": "", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 10}]},
          "unit": "short"
        }
      },
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 1},
      "id": 3,
      "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": {"calcs": ["sum"]}},
      "title": "RLS Bypass Events (last 1h)",
      "description": "Total count of requests served without RLS enforcement in the last hour. Any value > 0 is a security incident.",
      "type": "stat",
      "targets": [{"expr": "increase(gnwaas_log_lines_total{service=\"api-gateway\",level=\"warn\",message=~\".*RLS middleware.*failed to begin RLS transaction.*\"}[1h])", "legendFormat": "", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.99}, {"color": "green", "value": 0.999}]},
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 1},
      "id": 4,
      "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "title": "RLS Enforcement Rate (target: 100%)",
      "description": "Percentage of authenticated API requests that successfully activated RLS. Target is 100%.",
      "type": "stat",
      "targets": [{"expr": "1 - (rate(gnwaas_log_lines_total{service=\"api-gateway\",level=\"warn\",message=~\".*RLS middleware.*failed.*\"}[10m]) / rate(http_requests_total{service=\"api-gateway\"}[10m]))", "legendFormat": "", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 100}, {"color": "red", "value": 500}]},
          "unit": "ms"
        }
      },
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 1},
      "id": 5,
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "center", "reduceOptions": {"calcs": ["mean"]}},
      "title": "RLS Transaction Setup Overhead (p95)",
      "description": "Time added by the RLS middleware to begin a transaction and set session variables. Should be <10ms.",
      "type": "stat",
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(gnwaas_rls_setup_duration_seconds_bucket[5m])) by (le)) * 1000", "legendFormat": "", "refId": "A"}]
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 6},
      "id": 10,
      "title": "RLS Bypass Events Over Time",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"fixedColor": "red", "mode": "fixed"},
          "custom": {"drawStyle": "bars", "fillOpacity": 80, "lineWidth": 1, "showPoints": "never"},
          "unit": "short"
        }
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 7},
      "id": 11,
      "options": {"legend": {"calcs": ["sum"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "single"}},
      "title": "RLS Bypass Events per Minute — Any bar above zero is a CRITICAL security incident",
      "type": "timeseries",
      "targets": [
        {"expr": "increase(gnwaas_log_lines_total{service=\"api-gateway\",level=\"warn\",message=~\".*RLS middleware.*failed to begin RLS transaction.*\"}[1m])", "legendFormat": "RLS bypass events", "refId": "A"}
      ]
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 15},
      "id": 20,
      "title": "API Gateway Request Volume & RLS Coverage",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never"},
          "unit": "reqps"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "id": 21,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi"}},
      "title": "api-gateway Request Rate by Status Code",
      "type": "timeseries",
      "targets": [
        {"expr": "sum(rate(http_requests_total{service=\"api-gateway\",status=~\"2..\"}[5m]))", "legendFormat": "2xx (success)", "refId": "A"},
        {"expr": "sum(rate(http_requests_total{service=\"api-gateway\",status=~\"4..\"}[5m]))", "legendFormat": "4xx (client error)", "refId": "B"},
        {"expr": "sum(rate(http_requests_total{service=\"api-gateway\",status=~\"5..\"}[5m]))", "legendFormat": "5xx (server error)", "refId": "C"}
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never"},
          "unit": "reqps"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "id": 22,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi"}},
      "title": "api-gateway Request Rate by Endpoint (top 10)",
      "type": "timeseries",
      "targets": [
        {"expr": "topk(10, sum(rate(http_requests_total{service=\"api-gateway\"}[5m])) by (path))", "legendFormat": "{{path}}", "refId": "A"}
      ]
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 24},
      "id": 30,
      "title": "Sentinel Anomaly Detection",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never"},
          "unit": "short"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 25},
      "id": 31,
      "options": {"legend": {"calcs": ["sum"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi"}},
      "title": "Anomaly Flags Created per Hour by Severity",
      "type": "timeseries",
      "targets": [
        {"expr": "increase(gnwaas_anomaly_flags_total{severity=\"CRITICAL\"}[1h])", "legendFormat": "CRITICAL", "refId": "A"},
        {"expr": "increase(gnwaas_anomaly_flags_total{severity=\"HIGH\"}[1h])", "legendFormat": "HIGH", "refId": "B"},
        {"expr": "increase(gnwaas_anomaly_flags_total{severity=\"MEDIUM\"}[1h])", "legendFormat": "MEDIUM", "refId": "C"},
        {"expr": "increase(gnwaas_anomaly_flags_total{severity=\"LOW\"}[1h])", "legendFormat": "LOW", "refId": "D"}
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never"},
          "unit": "s"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 25},
      "id": 32,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi"}},
      "title": "Sentinel District Scan Duration",
      "type": "timeseries",
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(gnwaas_sentinel_scan_duration_seconds_bucket[5m])) by (le, district_id))", "legendFormat": "p95 {{district_id}}", "refId": "A"}
      ]
    }
  ],
  "refresh": "15s",
  "schemaVersion": 38,
  "tags": ["gn-waas", "security", "rls", "compliance"],
  "time": {"from": "now-3h", "to": "now"},
  "timezone": "browser",
  "title": "GN-WAAS \u2014 RLS Security & Compliance",
  "uid": "gnwaas-rls-security",
  "version": 1
}
