{
  "__inputs": [{"name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus"}],
  "description": "GN-WAAS PostgreSQL overview: connections, query throughput, cache hit ratio, replication lag, and table bloat.",
  "editable": false,
  "graphTooltip": 1,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "title": "Database Health",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 80}, {"color": "red", "value": 95}]},
          "unit": "short",
          "min": 0,
          "max": 100
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "id": 2,
      "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "title": "Active Connections (% of max_connections)",
      "type": "stat",
      "targets": [{"expr": "100 * pg_stat_activity_count{datname=\"gnwaas\"} / pg_settings_max_connections", "legendFormat": "", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.90}, {"color": "green", "value": 0.99}]},
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 1},
      "id": 3,
      "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "title": "Buffer Cache Hit Ratio (target: >99%)",
      "type": "stat",
      "targets": [{"expr": "sum(pg_stat_database_blks_hit{datname=\"gnwaas\"}) / (sum(pg_stat_database_blks_hit{datname=\"gnwaas\"}) + sum(pg_stat_database_blks_read{datname=\"gnwaas\"}))", "legendFormat": "", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 5}, {"color": "red", "value": 30}]},
          "unit": "s"
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 1},
      "id": 4,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "title": "Longest Running Query",
      "type": "stat",
      "targets": [{"expr": "max(pg_stat_activity_max_tx_duration{datname=\"gnwaas\",state=\"active\"})", "legendFormat": "", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 10}, {"color": "red", "value": 50}]},
          "unit": "short"
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 1},
      "id": 5,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "title": "Idle in Transaction Connections",
      "type": "stat",
      "targets": [{"expr": "pg_stat_activity_count{datname=\"gnwaas\",state=\"idle in transaction\"}", "legendFormat": "", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 10}]},
          "unit": "short"
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 1},
      "id": 6,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "title": "Lock Waits",
      "type": "stat",
      "targets": [{"expr": "pg_locks_count{datname=\"gnwaas\",mode=\"ExclusiveLock\",granted=\"false\"}", "legendFormat": "", "refId": "A"}]
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
      "id": 10,
      "title": "Query Throughput",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never"},
          "unit": "ops"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
      "id": 11,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi"}},
      "title": "Transactions per Second (commits + rollbacks)",
      "type": "timeseries",
      "targets": [
        {"expr": "rate(pg_stat_database_xact_commit{datname=\"gnwaas\"}[5m])", "legendFormat": "commits/s", "refId": "A"},
        {"expr": "rate(pg_stat_database_xact_rollback{datname=\"gnwaas\"}[5m])", "legendFormat": "rollbacks/s", "refId": "B"}
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never"},
          "unit": "ops"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
      "id": 12,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi"}},
      "title": "Rows Fetched / Inserted / Updated / Deleted per Second",
      "type": "timeseries",
      "targets": [
        {"expr": "rate(pg_stat_database_tup_fetched{datname=\"gnwaas\"}[5m])", "legendFormat": "fetched/s", "refId": "A"},
        {"expr": "rate(pg_stat_database_tup_inserted{datname=\"gnwaas\"}[5m])", "legendFormat": "inserted/s", "refId": "B"},
        {"expr": "rate(pg_stat_database_tup_updated{datname=\"gnwaas\"}[5m])", "legendFormat": "updated/s", "refId": "C"},
        {"expr": "rate(pg_stat_database_tup_deleted{datname=\"gnwaas\"}[5m])", "legendFormat": "deleted/s", "refId": "D"}
      ]
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 14},
      "id": 20,
      "title": "Connections Over Time",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never"},
          "unit": "short"
        }
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 15},
      "id": 21,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi"}},
      "title": "Active Connections by State",
      "type": "timeseries",
      "targets": [
        {"expr": "pg_stat_activity_count{datname=\"gnwaas\",state=\"active\"}", "legendFormat": "active", "refId": "A"},
        {"expr": "pg_stat_activity_count{datname=\"gnwaas\",state=\"idle\"}", "legendFormat": "idle", "refId": "B"},
        {"expr": "pg_stat_activity_count{datname=\"gnwaas\",state=\"idle in transaction\"}", "legendFormat": "idle in tx", "refId": "C"},
        {"expr": "pg_stat_activity_count{datname=\"gnwaas\",state=\"idle in transaction (aborted)\"}", "legendFormat": "idle in tx (aborted)", "refId": "D"}
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["gn-waas", "postgresql", "database"],
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "browser",
  "title": "GN-WAAS \u2014 PostgreSQL Overview",
  "uid": "gnwaas-postgresql",
  "version": 1
}
