{
  "realm": "gnwaas",
  "displayName": "GN-WAAS — Ghana National Water Audit & Assurance System",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "bruteForceProtected": true,
  "maxFailureWaitSeconds": 900,
  "failureFactor": 5,
  "accessTokenLifespan": 3600,
  "ssoSessionIdleTimeout": 28800,
  "ssoSessionMaxLifespan": 86400,
  "clients": [
    {
      "clientId": "gnwaas-admin-portal",
      "name": "GN-WAAS Admin Portal",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost:5173/*", "https://gnwaas.nita.gov.gh/*"],
      "webOrigins": ["http://localhost:5173", "https://gnwaas.nita.gov.gh"],
      "protocol": "openid-connect",
      "attributes": { "pkce.code.challenge.method": "S256" }
    },
    {
      "clientId": "gnwaas-api-gateway",
      "name": "GN-WAAS API Gateway",
      "enabled": true,
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "protocol": "openid-connect"
    }
  ],
  "roles": {
    "realm": [
      { "name": "SYSTEM_ADMIN",     "description": "Full system access" },
      { "name": "DISTRICT_MANAGER", "description": "District-level management" },
      { "name": "AUDIT_SUPERVISOR", "description": "Audit workflow management" },
      { "name": "FIELD_OFFICER",    "description": "Field audit execution" },
      { "name": "GRA_LIAISON",      "description": "GRA compliance and VAT recovery" },
      { "name": "FINANCE_ANALYST",  "description": "Financial reporting and NRW analysis" },
      { "name": "READONLY_VIEWER",  "description": "Read-only access" }
    ]
  },
  "passwordPolicy": "length(12) and upperCase(1) and lowerCase(1) and digits(1) and specialChars(1) and notUsername(undefined) and passwordHistory(5)",
  "otpPolicyType": "totp",
  "otpPolicyDigits": 6,
  "otpPolicyPeriod": 30,
  "eventsEnabled": true,
  "eventsExpiration": 2592000,
  "adminEventsEnabled": true,
  "adminEventsDetailsEnabled": true
}
