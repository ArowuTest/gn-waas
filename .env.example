# ============================================================
# GN-WAAS Root Environment Variables
# ============================================================
# Copy this file to .env and fill in production values.
# NEVER commit .env to version control.
#
# This file documents every variable consumed by docker-compose.yml.
# Each service also has its own .env.example in its directory for
# standalone (non-Docker) development.
# ============================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Superuser password for the postgres image (used only during init-db.sh).
POSTGRES_PASSWORD=change_me_in_production

# Password for gnwaas_admin role (BYPASSRLS — used by seed-runner only).
# Must be at least 20 characters in production.
GNWAAS_ADMIN_PASSWORD=change_me_in_production

# Password for gnwaas_app role (RLS-enforced — used by all backend services).
# Must be at least 20 characters in production.
GNWAAS_APP_PASSWORD=change_me_in_production

# ── Redis ─────────────────────────────────────────────────────────────────────
# Password for the Redis instance (used by api-gateway and sentinel).
REDIS_PASSWORD=change_me_in_production

# ── MinIO (Object Storage) ────────────────────────────────────────────────────
# Root user and password for MinIO (evidence photo storage).
MINIO_ROOT_USER=gnwaas_minio
MINIO_ROOT_PASSWORD=change_me_in_production

# ── Keycloak (Identity Provider) ─────────────────────────────────────────────
# Admin password for the Keycloak admin console.
KEYCLOAK_ADMIN_PASSWORD=change_me_in_production

# ── Grafana (Monitoring) ──────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_in_production

# ── Application ───────────────────────────────────────────────────────────────
# Set to "production" to skip demo seed data and enable production hardening.
APP_ENV=production

# Set to "false" in production. "true" bypasses JWT validation (dev only).
DEV_MODE=false

# Set to "false" in production. "true" uses GRA sandbox API (no real invoices).
GRA_SANDBOX_MODE=false
