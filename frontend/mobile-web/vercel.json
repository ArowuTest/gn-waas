{
  "version": 2,
  "name": "gnwaas-mobile",
  "buildCommand": null,
  "outputDirectory": ".",
  "routes": [
    {
      "src": "/flutter_service_worker.js",
      "headers": {
        "Cache-Control": "no-cache, no-store, must-revalidate"
      },
      "dest": "/flutter_service_worker.js"
    },
    {
      "src": "/assets/(.*)",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      },
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
