# GN-WAAS Consumer Portal — Environment Variables
# Copy to .env.local for local development

# API Gateway base URL (no trailing slash)
VITE_API_URL=http://localhost:3000

# Keycloak OIDC (production)
VITE_KEYCLOAK_URL=https://auth.gnwaas.gov.gh
VITE_KEYCLOAK_REALM=gnwaas
VITE_KEYCLOAK_CLIENT_ID=gnwaas-consumer-portal
