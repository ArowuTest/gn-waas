# GN-WAAS Admin Portal — Environment Variables
# Copy this file to .env.local for local development

# API Gateway base URL (no trailing slash, no /api/v1 suffix)
VITE_API_URL=http://localhost:3000

# Keycloak OIDC (used in production; dev mode uses /auth/dev-login)
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=gnwaas
VITE_KEYCLOAK_CLIENT_ID=gnwaas-admin-portal

# Set to "true" to enable dev-mode quick-login buttons
# NEVER set this in production
VITE_DEV_MODE=true
