# ─────────────────────────────────────────────────────────────────────────────
# GN-WAAS GRA Bridge — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── GRA VSDC API ──────────────────────────────────────────────────────────────
# BE-M02 fix: default to false in production. Set to true ONLY for local dev.
GRA_SANDBOX_MODE=false
GRA_VSDC_BASE_URL=https://vsdc.gra.gov.gh/api/v1
GRA_API_KEY=your_gra_api_key_here
GRA_BUSINESS_TIN=C0000000000

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8083
LOG_LEVEL=info
