# ─────────────────────────────────────────────────────────────────────────────
# GN-WAAS Meter Ingestor — Environment Variables
# Copy to .env and fill in values before running.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (required) ───────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gnwaas
DB_USER=gnwaas_app
DB_PASSWORD=                    # REQUIRED — no default in production
DB_SSL_MODE=require             # use 'disable' for local dev only

# ── NATS (optional — enables async event publishing) ─────────────────────────
# When set, meter-ingestor publishes:
#   gnwaas.meter.reading.received  → every reading ingested
#   gnwaas.sentinel.scan.trigger   → when inline pre-check detects anomaly
# Leave blank to disable NATS
NATS_URL=nats://localhost:4222

# ── gRPC Server ───────────────────────────────────────────────────────────────
GRPC_PORT=50051

# ── HTTP Server ───────────────────────────────────────────────────────────────
APP_PORT=3007
LOG_LEVEL=info

# ── Inline Anomaly Detection Thresholds ──────────────────────────────────────
# Pre-check thresholds applied before writing each reading
TAMPER_CONSUMPTION_SPIKE_FACTOR=5.0   # flag if reading > 5x monthly average
METER_ROLLBACK_TOLERANCE_M3=0.5       # flag if reading decreases by > 0.5 m³
FLOW_RATE_MAX_M3H=50.0                # flag if flow rate > 50 m³/hr
