# ─────────────────────────────────────────────────────────────────────────────
# GN-WAAS CDC Ingestor — Environment Variables
# Copy this file to .env and fill in real values before running.
# ─────────────────────────────────────────────────────────────────────────────

# ── GN-WAAS Target Database (required) ───────────────────────────────────────
# The PostgreSQL database where synced data is written
GNWAAS_DB_HOST=localhost
GNWAAS_DB_PORT=5432
GNWAAS_DB_NAME=gnwaas
GNWAAS_DB_USER=gnwaas_app
GNWAAS_DB_PASSWORD=change_me_in_production
GNWAAS_DB_SSLMODE=require

# ── GWL Source Database (required for live sync) ─────────────────────────────
# Read-only replica of Ghana Water Limited billing database
# Leave blank to run in DEMO mode (generates synthetic data)
GWL_DB_HOST=
GWL_DB_PORT=5432
GWL_DB_NAME=gwl_billing
GWL_DB_USER=gnwaas_readonly
GWL_DB_PASSWORD=
GWL_DB_SSLMODE=require

# ── NATS Messaging (optional) ─────────────────────────────────────────────────
# If not set, CDC ingestor runs without publishing events
NATS_URL=nats://localhost:4222

# ── Sync Configuration ────────────────────────────────────────────────────────
# How often to run automatic sync (minutes)
SYNC_INTERVAL_MINUTES=15
# Number of records per batch
SYNC_BATCH_SIZE=500
# Maximum rows to sync per run (0 = unlimited)
SYNC_MAX_ROWS=0

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8085
LOG_LEVEL=info
