# ─────────────────────────────────────────────────────────────────────────────
# GN-WAAS API Gateway — Environment Variables
# Copy this file to .env and fill in real values before running.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (required) ───────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gnwaas
DB_USER=gnwaas_app
DB_PASSWORD=change_me_in_production
DB_SSLMODE=require
DB_MAX_CONNS=20

# ── Keycloak (required in production) ────────────────────────────────────────
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=gnwaas
KEYCLOAK_CLIENT_ID=gnwaas-api

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
READ_TIMEOUT_SEC=30
WRITE_TIMEOUT_SEC=30
# Set to true ONLY for local development — bypasses JWT validation
DEV_MODE=false

# ── NATS (optional) ───────────────────────────────────────────────────────────
NATS_URL=nats://localhost:4222

# ── MinIO / Object Storage ────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_in_production
MINIO_BUCKET=gnwaas-evidence
MINIO_USE_SSL=false

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
