# ─────────────────────────────────────────────────────────────────────────────
# GN-WAAS Sentinel — Environment Variables
# Copy to .env and fill in values before running.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (required) ───────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gnwaas
DB_USER=gnwaas_app
DB_PASSWORD=                    # REQUIRED — no default in production
DB_SSL_MODE=require             # use 'disable' for local dev only

# ── Redis (caching + pub/sub) ────────────────────────────────────────────────
# INFRA-M01 fix: REDIS_PASSWORD must match the value in docker-compose.yml
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me_in_production

# ── NATS (optional — enables auto-scan on CDC sync events) ───────────────────
# When set, Sentinel subscribes to:
#   gnwaas.cdc.sync.completed  → scan all districts with new data
#   gnwaas.sentinel.scan.trigger → scan a specific district immediately
# Leave blank to disable NATS (sentinel will only scan via HTTP API)
NATS_URL=nats://localhost:4222

# ── HTTP Server ───────────────────────────────────────────────────────────────
APP_PORT=3002
LOG_LEVEL=info

# ── Anomaly Detection Thresholds ─────────────────────────────────────────────
# These can also be configured via the Admin Portal → Settings page
# (stored in system_config table, loaded at runtime)
BILLING_VARIANCE_THRESHOLD_PCT=15.0   # flag if shadow bill differs by >15%
PHANTOM_METER_MONTHS=6                # flag if reading unchanged for 6+ months
NIGHT_FLOW_THRESHOLD_PCT=30.0         # flag if night flow > 30% of daily avg
NRW_CRITICAL_THRESHOLD_PCT=60.0       # flag district if NRW > 60%
