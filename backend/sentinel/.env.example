# ─────────────────────────────────────────────────────────────────────────────
# GN-WAAS Sentinel — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (required) ───────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gnwaas
DB_USER=gnwaas_app
DB_PASSWORD=change_me_in_production
DB_SSLMODE=require

# ── NATS (optional) ───────────────────────────────────────────────────────────
NATS_URL=nats://localhost:4222

# ── Scan Schedule ─────────────────────────────────────────────────────────────
# Cron expression for sentinel scan (default: 2 AM daily)
SCAN_CRON=0 2 * * *
# Night flow analysis window (24h format)
NIGHT_FLOW_START_HOUR=2
NIGHT_FLOW_END_HOUR=4

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8082
LOG_LEVEL=info
